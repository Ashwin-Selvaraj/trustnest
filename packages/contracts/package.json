{
  "name": "@trustnest/contracts",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "hardhat compile && tsc -p tsconfig.typechain.json",
    "dev": "hardhat compile",
    "typecheck": "tsc --noEmit",
    "lint": "eslint scripts/ test/",
    "test": "hardhat test",
    "test:watch": "hardhat test --watch",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network amoy",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "node": "hardhat node"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.0.2",
    "hardhat": "^2.22.17",
    "ts-node": "^10.9.2"
  }
}
