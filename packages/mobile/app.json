{
  "expo": {
    "name": "TrustNest",
    "slug": "trustnest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "trustnest",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trustnest.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Required for KYC document capture",
        "NSPhotoLibraryUsageDescription": "Required for document upload"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.trustnest.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB",
          "sounds": []
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow TrustNest to access Face ID for secure storage"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8623f43e-f5f3-4c39-b13e-9b9af1eb2c89"
      }
    }
  }
}
