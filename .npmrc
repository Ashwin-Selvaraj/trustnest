# Hoist hardhat, chai, and ethers so all packages resolve the same instances.
# Required for @nomicfoundation/hardhat-chai-matchers to work correctly in pnpm workspaces.
public-hoist-pattern[]=*hardhat*
public-hoist-pattern[]=chai
public-hoist-pattern[]=ethers
public-hoist-pattern[]=@nomicfoundation*
public-hoist-pattern[]=@typechain*
public-hoist-pattern[]=typechain

# Hoist Expo and React Native packages so Metro bundler can resolve them.
# Metro uses its own resolver and cannot traverse pnpm's virtual store (.pnpm)
# without these packages being available at the workspace root node_modules.
public-hoist-pattern[]=@expo*
public-hoist-pattern[]=expo*
public-hoist-pattern[]=react-native*
public-hoist-pattern[]=@react-native*
public-hoist-pattern[]=@react-navigation*
